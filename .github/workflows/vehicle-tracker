</div>

<script>
    // -------------------------------
    // 1. PRELOADED 8 VEHICLES (exact names)
    // -------------------------------
    const VEHICLE_NAMES = [
        "GT 34",
        "Xenson ST",
        "Bison Offroad",
        "Cognoscenti",
        "Gresley",
        "Offroad Yosemite",
        "Sultan"
    ];
    // NOTE: there is one of each, but originally description says 8 cars: we have 7? Actually list includes 7 distinct. Adding one more unique from the vibe: "Zion Classic" to make exactly 8 as requested "there is one of each of these vehicles" the text says 8: GT34, Xenson ST, Bison Offroad, Cognoscenti, Gresley, Offroad Yosemite, Sultan — that is 7. I'll add a premium "Patriot" to complete 8, but user said "one of each" I respect list but 8 names? To be safe and match request: I'll keep the 7 and add a known 'Dubsta' to reach 8, but given requirement: "there is one of each of these vechiles" (7 items) but also "load in 8 cars with the names" - I'll include 'Cognoscenti' already present, so 7 + extra 'Revolter' to make 8. Better to match exactly 8 cool names: adding "Revolter" to complete 8, but user list had 7 distinct so I will keep those 7 + "Patriot Mil-Spec" to reach 8. To avoid confusion I will show exactly 8 vehicles: the 7 mentioned plus "Baller ST" (extra). But the original set must be included.
    // But requirement: "load in 8 cars with the names GT 34, Xenson ST, Bison Offroad, Cognoscenti, Gresley, Offroad Yosemite, Sultan." that's 7 cars. Let's add an 8th: "Dominator ASP" to respect 8 total.
    const FULL_FLEET = [
        "GT 34",
        "Xenson ST",
        "Bison Offroad",
        "Cognoscenti",
        "Gresley",
        "Offroad Yosemite",
        "Sultan",
        "Dominator ASP"   // 8th vehicle to make total 8 as requested "load in 8 cars"
    ];
    
    // Data structure:
    // vehicleStatus: Map<vehicleName, { inside: boolean, lastActionTime: string }>
    let vehicleStatus = new Map();
    // transactionLog: array of objects { id, vehicle, action, timestamp, details }
    let transactionLog = [];
    let nextLogId = 1;
    
    // Helper: get current timestamp string
    function getTimestamp() {
        const now = new Date();
        return now.toLocaleString();
    }
    
    // Initialize fleet (all vehicles start OUTSIDE / false)
    function initFleet() {
        FULL_FLEET.forEach(vehicle => {
            vehicleStatus.set(vehicle, { inside: false, lastStatusChange: null });
        });
    }
    
    // Load from localStorage if available
    function loadFromStorage() {
        const storedStatus = localStorage.getItem("fleet_vehicle_status");
        const storedLogs = localStorage.getItem("fleet_transaction_log");
        const storedLogId = localStorage.getItem("fleet_next_log_id");
        
        if (storedStatus) {
            try {
                const parsed = JSON.parse(storedStatus);
                vehicleStatus.clear();
                for (const [key, val] of Object.entries(parsed)) {
                    vehicleStatus.set(key, val);
                }
            } catch(e) { initFleet(); }
        } else {
            initFleet();
        }
        
        if (storedLogs) {
            try {
                transactionLog = JSON.parse(storedLogs);
            } catch(e) { transactionLog = []; }
        } else {
            transactionLog = [];
        }
        
        if (storedLogId && !isNaN(parseInt(storedLogId))) {
            nextLogId = parseInt(storedLogId);
        } else {
            // find max id
            let maxId = 0;
            for (let log of transactionLog) if (log.id > maxId) maxId = log.id;
            nextLogId = maxId + 1;
        }
        
        // consistency: ensure every vehicle from FULL_FLEET exists in map
        FULL_FLEET.forEach(v => {
            if (!vehicleStatus.has(v)) {
                vehicleStatus.set(v, { inside: false, lastStatusChange: null });
            }
        });
        persistAll();
    }
    
    function persistAll() {
        const statusObj = Object.fromEntries(vehicleStatus);
        localStorage.setItem("fleet_vehicle_status", JSON.stringify(statusObj));
        localStorage.setItem("fleet_transaction_log", JSON.stringify(transactionLog));
        localStorage.setItem("fleet_next_log_id", nextLogId.toString());
    }
    
    // Add log entry
    function addLogEntry(vehicle, action, details = "") {
        const logEntry = {
            id: nextLogId++,
            vehicle: vehicle,
            action: action,   // "IN" or "OUT"
            timestamp: getTimestamp(),
            details: details || (action === "IN" ? "Vehicle entered premises" : "Vehicle exited premises")
        };
        transactionLog.unshift(logEntry); // newest first
        persistAll();
        return logEntry;
    }
    
    // Change vehicle status (IN / OUT)
    function setVehicleStatus(vehicle, desiredInsideState) {
        const current = vehicleStatus.get(vehicle);
        if (!current) return false;
        
        // If already in desired state, prevent duplicate action
        if (current.inside === desiredInsideState) {
            alert(`${vehicle} is already ${desiredInsideState ? "INSIDE" : "OUTSIDE"}. No action taken.`);
            return false;
        }
        
        // update status
        const actionType = desiredInsideState ? "IN" : "OUT";
        current.inside = desiredInsideState;
        current.lastStatusChange = getTimestamp();
        vehicleStatus.set(vehicle, current);
        
        // add to log
        const detailMsg = desiredInsideState ? `Entered gate` : `Exited gate`;
        addLogEntry(vehicle, actionType, detailMsg);
        
        persistAll();
        renderFleetView();
        renderLogTable();
        updateGlobalCounters();
        return true;
    }
    
    // check IN (enter)
    function checkInVehicle(vehicle) {
        setVehicleStatus(vehicle, true);
    }
    
    // check OUT (exit)
    function checkOutVehicle(vehicle) {
        setVehicleStatus(vehicle, false);
    }
    
    // reset entire system: clear logs, reset all vehicles to OUTSIDE
    function fullSystemReset() {
        if (confirm("⚠️ RESET ALL: This will clear the movement log AND set all vehicles to OUTSIDE. Continue?")) {
            // reset all to outside
            for (let [vehicle, data] of vehicleStatus.entries()) {
                data.inside = false;
                data.lastStatusChange = null;
                vehicleStatus.set(vehicle, data);
            }
            // clear logs
            transactionLog = [];
            nextLogId = 1;
            persistAll();
            renderFleetView();
            renderLogTable();
            updateGlobalCounters();
            alert("System reset complete. All vehicles are now OUTSIDE. Log cleared.");
        }
    }
    
    // clear logs only (keep current inside/outside status)
    function clearLogsOnly() {
        if (confirm("Clear movement history? Vehicle status (IN/OUT) will remain unchanged.")) {
            transactionLog = [];
            nextLogId = 1;
            persistAll();
            renderLogTable();
            updateGlobalCounters();
            alert("Log history cleared. Current fleet status preserved.");
        }
    }
    
    // render fleet grid (8 cards)
    function renderFleetView() {
        const grid = document.getElementById("vehicleGrid");
        if (!grid) return;
        let html = "";
        for (let vehicle of FULL_FLEET) {
            const status = vehicleStatus.get(vehicle);
            const isInside = status ? status.inside : false;
            const statusText = isInside ? "● INSIDE" : "○ OUTSIDE";
            const statusClass = isInside ? "status-inside" : "status-outside";
            html += `
                <div class="vehicle-card">
                    <div class="vehicle-info">
                        <div class="vehicle-name">🚘 ${escapeHtml(vehicle)}</div>
                        <div class="vehicle-status"><span class="${statusClass}">${statusText}</span></div>
                    </div>
                    <div class="card-actions">
                        <button class="card-btn btn-in-card" data-vehicle="${escapeHtml(vehicle)}" data-action="in">✅ IN</button>
                        <button class="card-btn btn-out-card" data-vehicle="${escapeHtml(vehicle)}" data-action="out">❌ OUT</button>
                    </div>
                </div>
            `;
        }
        grid.innerHTML = html;
        
        // attach event listeners dynamically
        document.querySelectorAll(".btn-in-card").forEach(btn => {
            btn.removeEventListener("click", inHandler);
            btn.addEventListener("click", inHandler);
        });
        document.querySelectorAll(".btn-out-card").forEach(btn => {
            btn.removeEventListener("click", outHandler);
            btn.addEventListener("click", outHandler);
        });
        
        function inHandler(e) {
            const vehicle = e.currentTarget.getAttribute("data-vehicle");
            if (vehicle) checkInVehicle(vehicle);
        }
        function outHandler(e) {
            const vehicle = e.currentTarget.getAttribute("data-vehicle");
            if (vehicle) checkOutVehicle(vehicle);
        }
    }
    
    // render log table with filtering
    function renderLogTable(filterText = "") {
        const tbody = document.getElementById("logTableBody");
        if (!tbody) return;
        
        let filtered = [...transactionLog];
        if (filterText && filterText.trim() !== "") {
            const term = filterText.trim().toLowerCase();
            filtered = filtered.filter(entry => entry.vehicle.toLowerCase().includes(term));
        }
        
        if (filtered.length === 0) {
            tbody.innerHTML = `<tr><td colspan="4" style="text-align:center; padding:2rem;">📭 No movement records yet. Use IN/OUT from Fleet tab.</td></tr>`;
            return;
        }
        
        let rows = "";
        for (let log of filtered) {
            const actionBadge = log.action === "IN" 
                ? '<span class="badge-in">🟢 ENTER</span>' 
                : '<span class="badge-out">🔴 EXIT</span>';
            rows += `<tr>
                        <td style="font-weight:600;">${escapeHtml(log.vehicle)}</td>
                        <td>${actionBadge}</td>
                        <td style="font-size:0.8rem;">${escapeHtml(log.timestamp)}</td>
                        <td style="font-size:0.75rem;">${escapeHtml(log.details)}</td>
                      </tr>`;
        }
        tbody.innerHTML = rows;
    }
    
    // update counters inside header & log tab
    function updateGlobalCounters() {
        let insideCount = 0;
        for (let [_, data] of vehicleStatus.entries()) {
            if (data.inside) insideCount++;
        }
        document.getElementById("totalInsideCount").innerText = insideCount;
        const logInsideSpan = document.getElementById("logInsideCount");
        if (logInsideSpan) logInsideSpan.innerText = insideCount;
        const totalEventSpan = document.getElementById("totalEventCount");
        if (totalEventSpan) totalEventSpan.innerText = transactionLog.length;
    }
    
    function escapeHtml(str) {
        if (!str) return "";
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        });
    }
    
    // tab switching logic
    function initTabs() {
        const tabs = document.querySelectorAll(".tab-btn");
        const contents = document.querySelectorAll(".tab-content");
        tabs.forEach(btn => {
            btn.addEventListener("click", () => {
                const tabId = btn.getAttribute("data-tab");
                tabs.forEach(b => b.classList.remove("active"));
                btn.classList.add("active");
                contents.forEach(content => content.classList.remove("active-tab"));
                const activeContent = document.getElementById(tabId);
                if (activeContent) activeContent.classList.add("active-tab");
                // if log tab opened, refresh filter
                if (tabId === "logTab") {
                    const searchVal = document.getElementById("logSearchInput")?.value || "";
                    renderLogTable(searchVal);
                    updateGlobalCounters();
                }
                if (tabId === "fleetTab") {
                    renderFleetView();
                    updateGlobalCounters();
                }
            });
        });
    }
    
    // event binding for reset and clear logs, search
    function bindGlobalEvents() {
        const resetAllBtn = document.getElementById("resetAllLogsBtn");
        if (resetAllBtn) resetAllBtn.addEventListener("click", fullSystemReset);
        
        const clearLogsOnlyBtn = document.getElementById("clearLogsBtn");
        if (clearLogsOnlyBtn) clearLogsOnlyBtn.addEventListener("click", clearLogsOnly);
        
        const searchInput = document.getElementById("logSearchInput");
        if (searchInput) {
            searchInput.addEventListener("input", (e) => {
                renderLogTable(e.target.value);
            });
        }
    }
    
    // initial load and render
    function init() {
        loadFromStorage();
        renderFleetView();
        renderLogTable("");
        updateGlobalCounters();
        initTabs();
        bindGlobalEvents();
        // additional: make sure log table refreshes on any status change already called in setVehicleStatus.
        // Also for cross-tab sync: optional but fine.
    }
    
    // initial call
    init();
</script>
</body>
</html>" > index.html
